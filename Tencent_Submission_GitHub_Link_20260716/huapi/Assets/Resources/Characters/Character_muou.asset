  personality: "\u6765\u5386\u4E0D\u660E\u7684\u6728\u5076\u827A\u4EBA\uFF0C\u5E26\u7740\u4E00\u4E2A\u7CBE\u81F4\u7684\u63D0\u7EBF\u6728\u5076\u5728\u620F\u73ED\u9644\u8FD1\u6E38\u8361\u3002\u4ECE\u4E0D\u8BF4\u8BDD\uFF0C\u53EA\u7528\u6728\u5076\u4E0E\u4EBA\u4EA4\u6D41\u3002\u90A3\u53CC\u7A7A\u6D1E\u7684\u6728\u5076\u773C\u775B\u4EFF\u4F5B\u80FD\u770B\u7A7F\u4E00\u5207\u3002"
  fullBodyCG: {fileID: 0}
  faceMaskSprite: {fileID: 0}
  secret: "\u58A8\u4F36\u662F\u5341\u5E74\u524D\u53E6\u4E00\u573A\u620F\u73ED\u706B\u707E\u7684\u5E78\u5B58\u8005\uFF0C\u90A3\u573A\u706B\u707E\u593A\u8D70\u4E86\u4ED6\u5168\u5BB6\u7684\u6027\u547D\u3002\u4ED6\u7684\u6728\u5076\u4E2D\u85CF\u7740\u5F53\u5E74\u7684\u771F\u76F8\u3002\u4ED6\u6765\u5230\u8FD9\u4E2A\u620F\u73ED\uFF0C\u662F\u4E3A\u4E86\u963B\u6B62\u540C\u6837\u7684\u60B2\u5267\u518D\u6B21\u53D1\u751F\u2014\u2014\u6216\u8005\uFF0C\u662F\u4E3A\u4E86\u5B8C\u6210\u81EA\u5DF1\u7684\u590D\u4EC7\u3002"
  trueStory: "\u58A8\u4F36\u7684\u6728\u5076\u662F\u7528\u5F53\u5E74\u706B\u707E\u4E2D\u70E7\u6BC1\u7684\u620F\u670D\u7528\u6599\u5236\u4F5C\u7684\u3002\u6BCF\u4E00\u4E2A\u6728\u5076\u5173\u8282\u91CC\u90FD\u85CF\u7740\u4E00\u5F20\u7EB8\u6761\uFF0C\u8BB0\u5F55\u7740\u5341\u5E74\u524D\u90A3\u573A\u706B\u707E\u7684\u771F\u76F8\u3002\u4ED6\u7B49\u5F85\u4E86\u5341\u5E74\uFF0C\u53EA\u4E3A\u7B49\u5230\u5E55\u540E\u9ED1\u624B\u518D\u6B21\u73B0\u8EAB\u3002"
