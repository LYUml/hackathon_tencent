  personality: "\u8868\u9762\u67D4\u5F31\uFF0C\u5B9E\u5219\u5FC3\u601D\u7F1C\u5BC6\u3002\u603B\u662F\u5B89\u9759\u5730\u89C2\u5BDF\u7740\u620F\u73ED\u91CC\u7684\u4E00\u5207\u3002\u5979\u5BF9\u59D0\u59D0\u7684\u5931\u8E2A\u59CB\u7EC8\u803F\u803F\u4E8E\u6000\uFF0C\u4E0D\u76F8\u4FE1\u5B98\u5E9C\u7684\u300C\u610F\u5916\u300D\u7ED3\u8BBA\u3002"
  fullBodyCG: {fileID: 0}
