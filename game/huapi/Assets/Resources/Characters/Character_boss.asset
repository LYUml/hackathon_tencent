  publicIdentity: "\u620F\u73ED\u8001\u677F"
  trueIdentity: "\u77E5\u60C5\u8005"
  personality: "\u5FB7\u9AD8\u671B\u91CD\u7684\u620F\u73ED\u8001\u677F\uFF0C\u5BF9\u620F\u73ED\u6709\u7740\u6DF1\u539A\u611F\u60C5\u3002\u8868\u9762\u4E0A\u5BF9\u5931\u8E2A\u6848\u75DB\u5FC3\u75BE\u9996\uFF0C\u79EF\u6781\u914D\u5408\u5B98\u5E9C\u8C03\u67E5\u3002\u4F46\u6BCF\u5F53\u6709\u4EBA\u63D0\u5230\u706B\u707E\u5F53\u665A\u7684\u7EC6\u8282\u65F6\uFF0C\u4ED6\u7684\u773C\u795E\u4F1A\u95EA\u70C1\u3002"
  fullBodyCG: {fileID: 0}
  faceMaskSprite: {fileID: 0}
  secret: "\u73ED\u4E3B\u8001\u7237\u77E5\u9053\u706B\u707E\u7684\u771F\u76F8\uFF0C\u4F46\u4ED6\u9009\u62E9\u4E86\u9690\u7792\u2014\u2014\u56E0\u4E3A\u771F\u76F8\u4E00\u65E6\u66DD\u5149\uFF0C\u6574\u4E2A\u620F\u73ED\u90FD\u5C06\u9762\u4E34\u706D\u9876\u4E4B\u707E\u3002\u4ED6\u7528\u91D1\u8138\u63A9\u9970\u7740\u5185\u5FC3\u7684\u6050\u60E7\uFF0C\u7528\u5A01\u4E25\u538B\u5236\u7740\u6240\u6709\u4EBA\u7684\u8FFD\u95EE\u3002"
  trueStory: "\u73ED\u4E3B\u8001\u7237\u5728\u51E0\u5341\u5E74\u524D\u6B20\u4E86\u4E00\u4E2A\u4EBA\u60C5\uFF0C\u5982\u4ECA\u8FD9\u4E2A\u4EBA\u60C5\u9700\u8981\u7528\u6574\u4E2A\u620F\u73ED\u6765\u507F\u8FD8\u3002\u5931\u8E2A\u6848\u53EA\u662F\u5F00\u59CB\uFF0C\u66F4\u5927\u7684\u9634\u8C0B\u6B63\u5728\u903C\u8FD1\u3002\u91D1\u8138\u4E4B\u4E0B\u662F\u4E00\u5F20\u88AB\u547D\u8FD0\u6298\u78E8\u5F97\u75B2\u60EB\u4E0D\u582A\u7684\u9762\u5B54\u3002"
  relatedClueIDs: []
